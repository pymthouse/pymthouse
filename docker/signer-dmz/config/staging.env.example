# Second signer stack — staging PymtHouse issuer (port 8090, separate datadir).
#   ./docker/signer-dmz/scripts/init-staging-data.sh
#   docker compose -f docker-compose.yml -f docker/signer-dmz/docker-compose.staging.yml \
#     --env-file docker/signer-dmz/config/staging.env -p pymthouse-signer-staging up -d --build
SIGNER_DMZ_HOST_PORT=8090
SIGNER_DMZ_BIND_HOST=127.0.0.1
SIGNER_DATA_DIR=./data-staging
OIDC_ISSUER=https://pymthouse-staging.vercel.app/api/v1/oidc
OIDC_AUDIENCE=https://pymthouse-staging.vercel.app/api/v1/oidc
JWKS_URI=https://pymthouse-staging.vercel.app/api/v1/oidc/jwks
# Match staging Vercel (SIGNER_NETWORK / ETH_RPC_URL / SIGNER_ETH_ADDR as needed).
SIGNER_NETWORK=arbitrum-one-mainnet
ETH_RPC_URL=https://arb1.arbitrum.io/rpc
