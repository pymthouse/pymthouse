# Third signer stack — pymthouse.com issuer (port 8091, keystore copy from ./data).
#
#   cp docker/signer-dmz/config/app.env.example docker/signer-dmz/config/app.env
#   ./docker/signer-dmz/scripts/init-app-data.sh
#   docker compose -f docker-compose.yml -f docker/signer-dmz/docker-compose.app.yml \
#     --env-file docker/signer-dmz/config/app.env -p pymthouse-signer-app up -d
#
# Host Apache: signer.pymthouse.com → https → 127.0.0.1:8091
# Production PymtHouse (Vercel or self-hosted at pymthouse.com):
#   NEXTAUTH_URL=https://pymthouse.com
#   SIGNER_INTERNAL_URL=https://signer.pymthouse.com
#   SIGNER_CLI_URL=https://signer.pymthouse.com/__signer_cli

SIGNER_DMZ_HOST_PORT=8091
SIGNER_DMZ_BIND_HOST=127.0.0.1
SIGNER_DATA_DIR=./data-app
NEXTAUTH_URL=https://pymthouse.com
OIDC_ISSUER=https://pymthouse.com/api/v1/oidc
OIDC_AUDIENCE=https://pymthouse.com/api/v1/oidc
JWKS_URI=https://pymthouse.com/api/v1/oidc/jwks
SIGNER_NETWORK=arbitrum-one-mainnet
ETH_RPC_URL=https://arb1.arbitrum.io/rpc
