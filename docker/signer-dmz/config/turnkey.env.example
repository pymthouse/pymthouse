# Turnkey signer bootstrap mode (optional).
# When TURNKEY_ORG_ID + TURNKEY_API_PUBLIC_KEY + TURNKEY_API_PRIVATE_KEY are all set,
# entrypoint runs signer-turnkey-bootstrap before livepeer starts.
# If any are unset, the container follows existing path-based keystore behavior.

# Required for Turnkey mode
TURNKEY_ORG_ID=4a6a9098-0f08-480f-b3a8-a8e1fbd5103e
TURNKEY_API_PUBLIC_KEY=
TURNKEY_API_PRIVATE_KEY=
SIGNER_ETH_KEYSTORE_PASSWORD=

# Optional
TURNKEY_WALLET_NAME=livepeer-remote-signer
TURNKEY_API_HOST=api.turnkey.com
# SIGNER_ETH_ADDR=0x...

# Usual signer-dmz vars
PORT=8080
CLI_PORT=8082
NEXTAUTH_URL=http://localhost:3001

# Local dev only: skip JWKS fetch and Apache JWT verification (no bearer token required).
# SIGNER_DMZ_DISABLE_AUTH=1
