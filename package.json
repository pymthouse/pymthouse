{
  "name": "pymthouse",
  "version": "0.2.2",
  "private": true,
  "engines": {
    "node": ">=20.18.1"
  },
  "scripts": {
    "predev": "npm run db:prepare",
    "dev": "next dev -p 3001 --webpack",
    "prebuild": "[ \"$VERCEL\" = '1' ] && echo 'Skipping db:prepare on Vercel' || npm run db:prepare",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "eslint .",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "npx tsx scripts/db-migrate.ts",
    "db:studio": "drizzle-kit studio",
    "proto:compile": "pbjs -t static-module -w es6 -o src/lib/proto-generated.js proto/lp_rpc.proto && pbts -o src/lib/proto-generated.d.ts src/lib/proto-generated.js",
    "bootstrap": "npx tsx scripts/bootstrap-admin.ts",
    "db:prepare": "npx tsx scripts/db-migrate.ts",
    "oidc:seed": "npx tsx scripts/seed-oidc.ts",
    "openmeter:bootstrap": "npx tsx scripts/openmeter-bootstrap.ts",
    "openmeter:railway:bootstrap": "bash scripts/openmeter-railway-bootstrap.sh",
    "railway:stack:env": "bash scripts/railway-apply-stack-env.sh",
    "railway:stack:deploy": "bash scripts/railway-deploy-stack.sh",
    "railway:preview:deploy": "bash scripts/railway-deploy-stack.sh preview",
    "railway:preview:migrate": "bash scripts/railway-migrate-preview-clearinghouse.sh",
    "vercel:preview:env": "bash scripts/apply-pymthouse-preview-vercel-env.sh",
    "railway:signer:env": "bash scripts/railway-apply-signer-env.sh",
    "railway:signer:deploy": "bash scripts/railway-apply-signer-env.sh production --deploy",
    "validate:env": "node scripts/validate-env.js",
    "test": "node --import ./src/test-env.ts --import tsx --test --test-force-exit \"src/**/*.test.ts\""
  },
  "dependencies": {
    "@braintree/sanitize-url": "^7.1.2",
    "@openmeter/sdk": "^1.0.0-beta.228",
    "@pymthouse/builder-sdk": "0.4.3",
    "@tailwindcss/postcss": "^4.1.18",
    "@turnkey/crypto": "^2.8.14",
    "@turnkey/react-wallet-kit": "^1.11.1",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "jose": "^6.2.1",
    "next": "16.2.6",
    "next-auth": "^4.24.0",
    "oidc-provider": "^9.7.0",
    "postgres": "^3.4.5",
    "protobufjs": "^7.6.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "uuid": "^14.0.0"
  },
  "overrides": {
    "@babel/core": "7.29.6",
    "esbuild": "^0.28.1",
    "ethers": {
      "ws": "^8.21.0"
    },
    "next-auth": {
      "uuid": "^11.1.1"
    },
    "js-yaml": "4.2.0",
    "postcss": "^8.5.10",
    "undici": "^7.28.0",
    "viem": {
      "ws": "^8.21.0"
    },
    "ws@7": "^7.5.11",
    "ws@8": "^8.21.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/oidc-provider": "^9.5.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/uuid": "^10.0.0",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.0.0",
    "eslint-config-next": "16.2.3",
    "postcss": "^8.5.10",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0"
  }
}
