{
  "name": "pymthouse",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "predev": "npm run db:prepare",
    "dev": "next dev -p 3001",
    "prebuild": "[ \"$VERCEL\" = '1' ] && echo 'Skipping db:prepare on Vercel' || npm run db:prepare",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "proto:compile": "pbjs -t static-module -w es6 -o src/lib/proto-generated.js proto/lp_rpc.proto && pbts -o src/lib/proto-generated.d.ts src/lib/proto-generated.js",
    "bootstrap": "npx tsx scripts/bootstrap-admin.ts",
    "db:prepare": "npx tsx scripts/db-migrate.ts",
    "oidc:seed": "npx tsx scripts/seed-oidc.ts",
    "validate:env": "node scripts/validate-env.js",
    "test": "node --import ./src/test-env.ts --import tsx --test --test-force-exit \"src/**/*.test.ts\""
  },
  "dependencies": {
    "@braintree/sanitize-url": "^7.1.2",
    "@tailwindcss/postcss": "^4.1.18",
    "@turnkey/crypto": "^2.8.14",
    "@turnkey/react-wallet-kit": "^1.11.1",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "jose": "^6.2.1",
    "next": "16.2.6",
    "next-auth": "^4.24.0",
    "oidc-provider": "^9.7.0",
    "postgres": "^3.4.5",
    "protobufjs": "^7.5.5",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "uuid": "^14.0.0"
  },
  "overrides": {
    "esbuild": "^0.25.12"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/oidc-provider": "^9.5.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/uuid": "^10.0.0",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.0.0",
    "eslint-config-next": "16.2.3",
    "postcss": "^8.5.10",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0"
  }
}
