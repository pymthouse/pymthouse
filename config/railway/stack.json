{
  "projectId": "dab233aa-dd5f-429d-8cc4-9042e8735e2b",
  "projectName": "PymtHouse",
  "environments": {
    "preview": "f2e1c8a8-432b-4977-a9ca-5660a1905887",
    "production": "eb6ec297-3a7c-4437-b211-8dfff2999db1"
  },
  "deployOrder": [
    "kafka",
    "openmeter-collector",
    "pymthouse"
  ],
  "services": {
    "kafka": {
      "kind": "image",
      "rootDirectory": "deploy/kafka",
      "railwayConfigFile": "/deploy/kafka/railway.json"
    },
    "openmeter-collector": {
      "kind": "image",
      "rootDirectory": "deploy/openmeter-collector",
      "railwayConfigFile": "/deploy/openmeter-collector/railway.json"
    },
    "pymthouse": {
      "kind": "repo",
      "manifest": "deploy/pymthouse/railway.json",
      "description": "Remote signer DMZ (Apache JWT + go-livepeer). Service name is pymthouse for historical reasons."
    }
  }
}
