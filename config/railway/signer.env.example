# Copy to config/railway/signer.env (gitignored), fill secrets, then:
#   bash scripts/railway-apply-signer-env.sh production
#   bash scripts/railway-apply-signer-env.sh production --deploy
#
# Auth: railway login  OR  export RAILWAY_API_TOKEN=...  OR  export RAILWAY_TOKEN=...

# --- Issuer (must match Vercel NEXTAUTH_URL host) ---
# production:
NEXTAUTH_URL=https://pymthouse.com
# preview:
# NEXTAUTH_URL=https://pymthouse-preview.up.railway.app

# --- Signer / chain ---
SIGNER_NETWORK=arbitrum-one-mainnet
ETH_RPC_URL=https://arb1.arbitrum.io/rpc

# --- Turnkey ephemeral keystore (set all four together) ---
TURNKEY_ORG_ID=
TURNKEY_API_PUBLIC_KEY=
TURNKEY_API_PRIVATE_KEY=
SIGNER_ETH_KEYSTORE_PASSWORD=

# --- Optional ---
TURNKEY_WALLET_NAME=livepeer-remote-signer
TURNKEY_API_HOST=api.turnkey.com
# SIGNER_ETH_ADDR=0x...

# --- Optional pymthouse service secrets (usually same as Vercel) ---
# DATABASE_URL=
# AUTH_TOKEN_PEPPER=
# NEXTAUTH_SECRET=
