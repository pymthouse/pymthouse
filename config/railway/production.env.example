# Copy to Railway production environment (per service) or pass to CI as GitHub Actions secrets.
# Use distinct values from preview for production secrets (passwords, API keys).
#
# CI: .github/workflows/deploy-railway-production.yml runs scripts/railway-apply-stack-env.sh
# with secrets/vars below. Unset repo variables fall back to the defaults in that workflow.
#
# | GitHub repository variable | Default (when unset) |
# |----------------------------|----------------------|
# | RAILWAY_PRODUCTION_NEXTAUTH_URL | https://pymthouse.com |
# | SIGNER_NETWORK | arbitrum-one-mainnet |
#
# | GitHub secret | Railway service |
# |---------------|-----------------|
# | RAILWAY_API_TOKEN | (CLI auth — Account → Tokens, not project Settings) |
# | RAILWAY_PRODUCTION_DATABASE_URL | pymthouse |
# | RAILWAY_PRODUCTION_AUTH_TOKEN_PEPPER | pymthouse |
# | RAILWAY_PRODUCTION_NEXTAUTH_SECRET | pymthouse |
# | OPENMETER_URL | openmeter-collector |
# | OPENMETER_INGEST_API_KEY | openmeter-collector |
# | WEBHOOK_SECRET | pymthouse (signer DMZ) + Vercel (remote-signer webhook) — same value |
# | TURNKEY_ORG_ID | pymthouse (Turnkey bootstrap — set all four together) |
# | TURNKEY_API_PUBLIC_KEY | pymthouse |
# | TURNKEY_API_PRIVATE_KEY | pymthouse |
# | SIGNER_ETH_KEYSTORE_PASSWORD | pymthouse |
# | ETH_RPC_URL | pymthouse (optional override) |
#
# | GitHub repository variable | Railway service |
# |----------------------------|-----------------|
# | TURNKEY_WALLET_NAME | pymthouse (default livepeer-remote-signer) |
# | SIGNER_ETH_ADDR | pymthouse (optional 0x pin) |

# --- kafka service ---
CLUSTER_ID=ca497efe-9f82-4b84-890b-d9969a9a2e1c

# --- openmeter-collector service ---
# Hosted Konnect/OpenMeter API base (region-specific):
#   https://us.api.konghq.com/v3/openmeter
#   https://eu.api.konghq.com/v3/openmeter
OPENMETER_URL=
OPENMETER_INGEST_URL=
# Konnect ingest defaults to ${OPENMETER_URL}/events when OPENMETER_INGEST_URL is unset.
OPENMETER_INGEST_API_KEY=
KAFKA_BROKERS=kafka.railway.internal:9092
KAFKA_GATEWAY_TOPIC=livepeer-gateway-events
PRICE_ORACLE_URL=https://api.coinbase.com/v2/prices/ETH-USD/spot
PRICE_ORACLE_REFRESH=5m
# App-side oracle fallback (eth-usd-oracle.ts), not used by the collector.
ETH_USD_PRICE=3500

# --- pymthouse (signer DMZ) ---
SIGNER_NETWORK=arbitrum-one-mainnet
ETH_RPC_URL=https://arb1.arbitrum.io/rpc
NEXTAUTH_URL=https://pymthouse.com
# Apache JWT iss/aud on signer DMZ (Next app derives issuer from NEXTAUTH_URL).
OIDC_ISSUER=https://pymthouse.com/api/v1/oidc
OIDC_AUDIENCE=https://pymthouse.com/api/v1/oidc
JWKS_URI=https://pymthouse.com/api/v1/oidc/jwks
# Signer session exchange (RFC 8693 at POST /api/v1/apps/{clientId}/oidc/token)
# SIGNER_TOKEN_AUDIENCE=   # optional; defaults to OIDC issuer URL
# DISCOVERY_URL=           # Livepeer network discovery URL in SignerSession.discovery_url
#                          # and livepeer-python-sdk --token (sdkToken on API key mint).
#                          # If unset, ORCH_WEBHOOK_URL is used as the sdkToken discovery fallback.
# Remote signer orchestrator pool (go-livepeer -orchWebhookUrl); requires SIGNER_REMOTE_DISCOVERY=1
SIGNER_REMOTE_DISCOVERY=1
ORCH_WEBHOOK_URL=https://discovery-service-production-8955.up.railway.app/v1/discovery/raw?serviceType=legacy
LIVE_AI_CAP_REPORT_INTERVAL=5m
REMOTE_SIGNER_WEBHOOK_URL=https://pymthouse.com/webhooks/remote-signer
WEBHOOK_SECRET=
KAFKA_BROKERS=kafka.railway.internal:9092
KAFKA_GATEWAY_TOPIC=livepeer-gateway-events
# Railway exposes one public port ($PORT). CLI stays on /__signer_cli (not CLI_PORT).
SIGNER_DMZ_ENABLE_CLI_LISTENER=0
# Turnkey ephemeral keystore bootstrap (set all four secrets together in GitHub/Railway).
# If any Turnkey credential is missing, signer falls back to /data keystore on volume.
TURNKEY_ORG_ID=
TURNKEY_WALLET_NAME=livepeer-remote-signer
TURNKEY_API_HOST=api.turnkey.com
SIGNER_ETH_ADDR=
# Secrets — GitHub Actions → scripts/railway-apply-stack-env.sh → Railway pymthouse:
# TURNKEY_API_PUBLIC_KEY
# TURNKEY_API_PRIVATE_KEY
# SIGNER_ETH_KEYSTORE_PASSWORD
# DATABASE_URL + AUTH_TOKEN_PEPPER + NEXTAUTH_SECRET: production Neon / Vercel values
#
# Vercel (Next app, separate from Railway pymthouse service):
# SIGNER_INTERNAL_URL=https://<pymthouse-production>.up.railway.app
# SIGNER_CLI_URL=https://<pymthouse-production>.up.railway.app/__signer_cli
#
# A/B signer version selection (Vercel / Next app only). The Railway stack now
# deploys two signer DMZs in production: pymthouse (stable) and
# pymthouse-signer-test (latest, newer go-livepeer build + BYOC per-cap pricing,
# same signing identity). All apps use the stable signer by default; only apps
# whose public OIDC client id (app_*) is listed in LATEST_SIGNER_APPS are routed
# to the latest DMZ. Leaving SIGNER_LATEST_URL unset makes the allowlist
# a safe no-op (opted-in apps fall back to stable).
# SIGNER_LATEST_URL=https://<pymthouse-signer-test-production>.up.railway.app
# LATEST_SIGNER_APPS=app_123,app_234
# Turnkey balance webhook → TicketBroker auto-funding (Vercel only).
# See docs/turnkey-ticket-funding.md for minimum deposit math and verification.
# TURNKEY_FUNDING_CAIP2=eip155:42161
# TICKET_FUNDING_GAS_BUFFER_WEI=100000000000000   # 0.0001 ETH gas reserve
# TICKET_FUNDING_MIN_WEI=1000000000000000          # 0.001 ETH min fund after buffer
# Minimum deposit (defaults): ~0.0011 ETH; recommend ≥ 0.002 ETH per transfer.
