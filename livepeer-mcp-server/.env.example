# --- PymtHouse / Livepeer MCP server configuration -------------------------
# All values are optional; the defaults target PymtHouse staging.

# Base PymtHouse origin. The OIDC issuer and REST API base are derived from it
# unless you override them explicitly below.
PYMTHOUSE_BASE_URL=https://staging.pymthouse.com

# OIDC issuer base used for the device-code login flow.
# Defaults to "${PYMTHOUSE_BASE_URL}/api/v1/oidc".
# LIVEPEER_OIDC_BASE_URL=https://staging.pymthouse.com/api/v1/oidc

# REST API base for the public capability/pricing endpoints.
# Defaults to "${PYMTHOUSE_BASE_URL}/api/v1".
# PYMTHOUSE_API_BASE_URL=https://staging.pymthouse.com/api/v1

# Public OIDC client id (the "app_..." / SDK client). Defaults to the SDK
# client registered with PymtHouse.
# LIVEPEER_CLIENT_ID=livepeer-sdk

# OAuth scopes requested during device login. Keep in sync with what the
# public client is allowed to request.
# LIVEPEER_SCOPES=openid profile gateway

# Discovery service used to route live (lv2v) jobs to orchestrators.
# REQUIRED for start_job.
# LIVEPEER_DISCOVERY_URL=https://discovery.example.com/v1/discovery/raw

# Optional default model id used when start_job is called without one.
# LIVEPEER_MODEL_ID=streamdiffusion-sdxl
