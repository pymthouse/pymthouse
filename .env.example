# pymthouse environment configuration

# ---------- App ----------
# Public Mintlify docs base URL (defaults to https://docs.pymthouse.com).
# NEXT_PUBLIC_DOCS_URL=https://docs.pymthouse.com
# Public-facing URL of the app. NextAuth uses this to build OAuth callback
# URLs sent to Google/GitHub (e.g. https://pymthouse.com/api/auth/callback/google).
# In production this must be your actual domain with HTTPS — NOT localhost — or
# OAuth redirects and OIDC device verification URLs will point to http and fail.
# If you set http://pymthouse.com, the app will auto-upgrade to https for
# non-localhost hosts. The registered callback URIs in your Google/GitHub OAuth
# apps must match:
#   {NEXTAUTH_URL}/api/auth/callback/google
#   {NEXTAUTH_URL}/api/auth/callback/github
NEXTAUTH_URL=http://localhost:3001
# When running behind a reverse proxy (e.g. Apache → localhost:3001), set
# NEXTAUTH_URL_INTERNAL so server-side NextAuth calls bypass the proxy and
# go directly to the local Next.js process. Leave unset for local dev.
# NEXTAUTH_URL_INTERNAL=http://localhost:3001
# Generate once and keep stable. Example:
#   openssl rand -base64 32
# If .env.local also sets NEXTAUTH_SECRET, it overrides this value.
NEXTAUTH_SECRET=replace-with-random-base64-secret

# Server-side pepper used by PBKDF2-SHA256 to hash bearer tokens, API keys,
# and OIDC refresh tokens before storage. Must be >=32 chars and kept stable
# for the lifetime of the deployment — changing this value invalidates every
# existing token_hash / key_hash row and requires re-issuing all credentials.
# Generate once:
#   openssl rand -base64 48
AUTH_TOKEN_PEPPER=replace-with-random-base64-pepper

# ---------- OAuth Providers (admin login) ----------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ---------- Database (PostgreSQL; Neon or any libpq URL) ----------
# Required. Migrations run on `npm run dev` / `npm run build` via db:prepare.
# Example (Neon): postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=postgresql://user:password@ep-example.us-east-2.aws.neon.tech/neondb?sslmode=require

# ---------- go-livepeer remote signer (local = full signer-dmz) ----------
# The local compose image is signer-dmz: Apache validates RS256 bearer tokens
# (iss/aud/scope) using the OIDC public key from JWKS — same model as production.
# Only PymtHouse-issued short-lived tokens reach go-livepeer; /status and /healthz
# stay open for health. Match SIGNER_DMZ_HOST_PORT in docker-compose (default 8080).
# Host publish binds to 127.0.0.1 by default (SIGNER_DMZ_BIND_HOST). Use
# 127.0.0.1 in URLs below when PymtHouse runs on the same host; remote callers
# need your server's hostname/IP and valid DMZ JWTs (scope=sign:job / admin).
# SIGNER_DMZ_BIND_HOST=0.0.0.0
# SIGNER_DMZ_HOST_PORT=8080
SIGNER_INTERNAL_URL=http://127.0.0.1:8080
# Apache CLI admin endpoint (admin scope): path-mounted on the same host/port as
# the signer HTTP API (SIGNER_CLI_URL default path /__signer_cli). Restrict with
# path- or host-level firewall and monitoring—not a separate listener port.
SIGNER_CLI_URL=http://127.0.0.1:8080/__signer_cli
# Optional: JWKS URL for signer-dmz (defaults: same issuer as NEXTAUTH_URL, host
# rewritten to host.docker.internal inside the container). jwks_to_pem allows
# https anywhere, or http only for localhost / 127.0.0.1 / host.docker.internal.
# If JWKS is HTTPS with a self-signed or corporate CA, set JWKS_TLS_INSECURE=1
# (signer-dmz `jwks_to_pem.py` only; not for production).
# SIGNER_DMZ_JWKS_URL=http://host.docker.internal:3001/api/v1/oidc/jwks
#
# Admin “restart signer” passes OIDC_ISSUER = getIssuer() and JWKS for that issuer
# so Apache validates the same JWTs this app mints (local oidc:seed keys).
SIGNER_NETWORK=arbitrum-one-mainnet
# Ethereum RPC endpoint for the signer
ETH_RPC_URL=https://arb1.arbitrum.io/rpc

# ---------- Turnkey Wallet Kit (embedded wallets) ----------
# From Turnkey dashboard → Wallet Kit / Auth Proxy
NEXT_PUBLIC_ORGANIZATION_ID=
NEXT_PUBLIC_AUTH_PROXY_CONFIG_ID=
# Optional: comma-separated organization UUIDs allowed for session JWTs (defense in depth)
# TURNKEY_ALLOWED_ORGANIZATION_IDS=

# ---------- OIDC ----------
# `npm run oidc:seed` now ensures only the signing key exists.
# Register confidential clients through the app dashboard or API,
# then rotate each client secret from `/api/v1/apps/{clientId}/credentials`.
#
# JWKS URL stored on developer_apps for RFC 8693 token exchange (public host).
# Defaults to https://pymthouse.com/api/v1/oidc/jwks — set for self-hosted only.
# PLATFORM_JWKS_URL=https://your-domain.com/api/v1/oidc/jwks
