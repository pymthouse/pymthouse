# pymthouse environment configuration

# ---------- App ----------
# Public Mintlify docs base URL (defaults to https://docs.pymthouse.com).
# NEXT_PUBLIC_DOCS_URL=https://docs.pymthouse.com
# Public-facing URL of the app. NextAuth uses this to build OAuth callback
# URLs sent to Google/GitHub (e.g. https://pymthouse.com/api/auth/callback/google).
# In production this must be your actual domain with HTTPS — NOT localhost — or
# OAuth redirects and OIDC device verification URLs will point to http and fail.
# If you set http://pymthouse.com, the app will auto-upgrade to https for
# non-localhost hosts. The registered callback URIs in your Google/GitHub OAuth
# apps must match:
#   {NEXTAUTH_URL}/api/auth/callback/google
#   {NEXTAUTH_URL}/api/auth/callback/github
NEXTAUTH_URL=http://localhost:3001
# When running behind a reverse proxy (e.g. Apache → localhost:3001), set
# NEXTAUTH_URL_INTERNAL so server-side NextAuth calls bypass the proxy and
# go directly to the local Next.js process. Leave unset for local dev.
# NEXTAUTH_URL_INTERNAL=http://localhost:3001
# Generate once and keep stable. Example:
#   openssl rand -base64 32
# If .env.local also sets NEXTAUTH_SECRET, it overrides this value.
NEXTAUTH_SECRET=replace-with-random-base64-secret

# Server-side pepper used by PBKDF2-SHA256 to hash bearer tokens, API keys,
# and OIDC refresh tokens before storage. Must be >=32 chars and kept stable
# for the lifetime of the deployment — changing this value invalidates every
# existing token_hash / key_hash row and requires re-issuing all credentials.
# Generate once:
#   openssl rand -base64 48
AUTH_TOKEN_PEPPER=replace-with-random-base64-pepper

# ---------- OAuth Providers (admin login) ----------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ---------- Database (PostgreSQL; Neon or any libpq URL) ----------
# Required. Migrations run on `npm run dev` / `npm run build` via db:prepare.
# Example (Neon): postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=postgresql://user:password@ep-example.us-east-2.aws.neon.tech/neondb?sslmode=require

# ---------- go-livepeer remote signer (local = full signer-dmz) ----------
# Clearinghouse stack (signer + kafka + collector): recommended for local dev
# Start the full stack so Kafka events reach the OpenMeter collector:
#   docker compose -f docker-compose.clearinghouse.railway.yml --env-file .env.local up -d --build
# go-livepeer binary source for signer-dmz-local build (published CI image by default):
# LIVEPEER_IMAGE=livepeer/go-livepeer:sha-33380bc9088cbd26b3797387dc6a783a68a69f84
# Or build DMZ only: ./scripts/build-local-signer.sh
# Standalone signer (no kafka): docker compose up -d signer-dmz
# The local compose image is signer-dmz: Apache validates RS256 bearer tokens
# (iss/aud/scope) using the OIDC public key from JWKS — same model as production.
# Only PymtHouse-issued short-lived tokens reach go-livepeer; /status and /healthz
# stay open for health. Match SIGNER_DMZ_HOST_PORT in docker-compose (default 8080).
# Host publish binds to 127.0.0.1 by default (SIGNER_DMZ_BIND_HOST). Use
# 127.0.0.1 in URLs below when PymtHouse runs on the same host; remote callers
# need your server's hostname/IP and valid DMZ JWTs (scope=sign:job / admin).
# Public TLS: host Apache → 127.0.0.1:8080 (see deploy/host-apache/). Do not bind 0.0.0.0 in production.
# SIGNER_DMZ_BIND_HOST=127.0.0.1
# SIGNER_DMZ_HOST_PORT=8080
SIGNER_INTERNAL_URL=http://127.0.0.1:8080
# Apache CLI admin endpoint (admin scope): path-mounted on the same host/port as
# the signer HTTP API (SIGNER_CLI_URL default path /__signer_cli). Restrict with
# path- or host-level firewall and monitoring—not a separate listener port.
SIGNER_CLI_URL=http://127.0.0.1:8080/__signer_cli
# Optional: JWKS URL for signer-dmz (defaults: same issuer as NEXTAUTH_URL, host
# rewritten to host.docker.internal inside the container). jwks_to_pem allows
# https anywhere, or http only for localhost / 127.0.0.1 / host.docker.internal.
# If JWKS is HTTPS with a self-signed or corporate CA, set JWKS_TLS_INSECURE=1
# (signer-dmz `jwks_to_pem.py` only; not for production).
# SIGNER_DMZ_JWKS_URL=http://host.docker.internal:3001/api/v1/oidc/jwks
#
# Admin “restart signer” passes OIDC_ISSUER = getIssuer() and JWKS for that issuer
# so Apache validates the same JWTs this app mints (local oidc:seed keys).
SIGNER_NETWORK=arbitrum-one-mainnet
# Ethereum RPC endpoint for the signer
ETH_RPC_URL=https://arb1.arbitrum.io/rpc
# Remote signer auth webhook (go-livepeer -> pymthouse webhook).
REMOTE_SIGNER_WEBHOOK_URL=http://host.docker.internal:3001/webhooks/remote-signer
# Shared secret for go-livepeer -remoteSignerWebhookHeaders (X-Api-Key:... in entrypoint.sh).
WEBHOOK_SECRET=
# Kafka monitor event bus for go-livepeer create_signed_ticket events.
KAFKA_BROKERS=kafka.railway.internal:9092
KAFKA_GATEWAY_TOPIC=livepeer-gateway-events
# Collector ETH/USD oracle (startup warm + periodic refresh).
PRICE_ORACLE_URL=https://api.coinbase.com/v2/prices/ETH-USD/spot
PRICE_ORACLE_REFRESH=5m
# App-side oracle fallback (eth-usd-oracle.ts), not used by the collector.
ETH_USD_PRICE=3500
# OIDC webhook verifier config (via @pymthouse/clearinghouse-identity-webhook legacy-env;
# JWT_* / CLAIM_* names are unchanged — mapped to OIDC_* internally).
# JWKS is resolved via OIDC discovery: {issuer}/.well-known/openid-configuration → jwks_uri.
# Optional override: OIDC_JWKS_URI=https://staging.pymthouse.com/api/v1/oidc/jwks
JWT_ISSUER=
JWT_AUDIENCE=
CLAIM_CLIENT_ID=client_id
CLAIM_USAGE_SUBJECT=external_user_id
USAGE_SUBJECT_TYPE=external_user_id
# ---------- OpenMeter (usage metering + trial credits) ----------
# Local: docker compose -f docker-compose.openmeter.yml up -d && npm run openmeter:bootstrap
# Hosted Konnect/OpenMeter (production): OPENMETER_URL=https://{region}.api.konghq.com/v3/openmeter
# Collector ingest (Konnect): defaults to ${OPENMETER_URL}/events
# OPENMETER_INGEST_URL=https://us.api.konghq.com/v3/openmeter/events
# Self-hosted Railway OpenMeter can still be used for local/on-prem testing.
OPENMETER_POSTGRES_SECRET=postgres
OPENMETER_CLICKHOUSE_SECRET=default
OPENMETER_URL=http://127.0.0.1:48888
# Route mode:
# - auto (default): infer from OPENMETER_URL / OPENMETER_API_KEY (app admin API key)
# - self_hosted: use OpenMeter SDK /api/v1 routes
# - hosted: use hosted Konnect-style routes (no /api/v1 prefix)
OPENMETER_ROUTE_MODE=auto
# Optional for local docker; required for OpenMeter Cloud / auth-enabled installs.
OPENMETER_API_KEY=
# Optional collector-only ingest key. Falls back to OPENMETER_API_KEY when unset.
OPENMETER_INGEST_API_KEY=
# Optional override for free Starter subscriptions (sandbox billing profile id in Konnect).
# OPENMETER_FREE_BILLING_PROFILE_ID=
OPENMETER_TRIAL_FEATURE_KEY=network_spend
# Default included usage (USD micros) when seeding per-app Starter plan (5000000 = $5)
OPENMETER_DEFAULT_STARTER_INCLUDED_USD_MICROS=5000000
# Required for usage totals, allowance balance, and signed-ticket metering
# OPENMETER_URL=http://127.0.0.1:48888

# Billing API v2 (see src/lib/billing/feature-flags.ts)
BILLING_PLANS_API_V2=true
BILLING_STABLE_FEATURE_KEYS=true

# ---------- BPP ② subscriptionRef ----------
# NaaP reads usage by PULLING from pymthouse (M2M client / builder-sdk usage
# helpers backed by OpenMeter). There is no outbound usage push from pymthouse.
# HMAC key for the OPAQUE BPP ② `subscriptionRef` (one-way; raw OpenMeter id is
# unrecoverable from the ref). Min 32 chars. If unset, falls back to
# AUTH_TOKEN_PEPPER with a one-time warning. Generate: openssl rand -base64 48
# SUBSCRIPTION_REF_SECRET=
# Authoritative metering path is Kafka -> collector -> OpenMeter.
# Set to true only during dual-write validation windows.
# ---------- Turnkey Wallet Kit (embedded wallets) ----------
# From Turnkey dashboard → Wallet Kit / Auth Proxy
NEXT_PUBLIC_ORGANIZATION_ID=
NEXT_PUBLIC_AUTH_PROXY_CONFIG_ID=
# Optional: comma-separated organization UUIDs allowed for session JWTs (defense in depth)
# TURNKEY_ALLOWED_ORGANIZATION_IDS=

# ---------- Turnkey balance → TicketBroker auto-funding ----------
# Turnkey balance webhook (balances:finalized) credits signer wallet deposits
# into TicketBroker via the protected /__signer_cli/fundDepositAndReserve route.
# Full guide: docs/turnkey-ticket-funding.md
# Register the webhook with: npm run turnkey:create-webhook
# TURNKEY_FUNDING_CAIP2=eip155:42161
# Amount held back from each deposit for gas (wei). Default: 100000000000000 (0.0001 ETH)
# TICKET_FUNDING_GAS_BUFFER_WEI=100000000000000
# Minimum credited to TicketBroker after buffer (wei). Default: 1000000000000000 (0.001 ETH)
# TICKET_FUNDING_MIN_WEI=1000000000000000
# Minimum incoming deposit (defaults): buffer + min + 1 wei ≈ 0.0011 ETH; send ≥ 0.002 ETH in practice.

# ---------- OIDC ----------
# `npm run oidc:seed` now ensures only the signing key exists.
# Register confidential clients through the app dashboard or API,
# then rotate each client secret from `/api/v1/apps/{clientId}/credentials`.
#
# JWKS URL stored on developer_apps for RFC 8693 token exchange (public host).
# Defaults to https://pymthouse.com/api/v1/oidc/jwks — set for self-hosted only.
# PLATFORM_JWKS_URL=https://your-domain.com/api/v1/oidc/jwks
