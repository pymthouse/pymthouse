{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "deploy/openmeter/Dockerfile"
  },
  "deploy": {
    "startCommand": "/entrypoint.sh openmeter",
    "numReplicas": 1,
    "sleepApplication": false,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10,
    "healthcheckPath": "/api/v1/debug/metrics",
    "healthcheckTimeout": 900
  }
}
