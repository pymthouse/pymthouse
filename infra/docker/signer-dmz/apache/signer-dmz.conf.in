# Templated with envsubst: PORT, CLI_PORT, SIGNER_HTTP_ADDR, SIGNER_CLI_HTTP_ADDR,
#                           OIDC_ISSUER, OIDC_AUDIENCE, JWT_PEM_PATH

ServerName localhost
ServerTokens Prod
ServerSignature Off

# Log to container stdout/stderr so `docker logs` surfaces auth failures
# (mod_authnz_jwt logs rejection reasons at `info` — raise APACHE_AUTH_JWT_LOG_LEVEL
# for debugging JWT verification, then lower it once the DMZ is trusted). The
# `warn` prefix applies to all other modules; only the auth_jwt channel follows
# APACHE_AUTH_JWT_LOG_LEVEL (compose default is typically `info`).
ErrorLog /dev/stderr
LogLevel warn auth_jwt:${APACHE_AUTH_JWT_LOG_LEVEL}

LogFormat "%h %l %u %t \"%r\" %>s %b \"%{Referer}i\" \"%{User-Agent}i\"" signer_combined
CustomLog /dev/stdout signer_combined

# Scope in logs: mod_authnz_jwt does not expose arbitrary JWT claims to LogFormat; use mod_lua or a sidecar. Never log the Authorization header.

<VirtualHost *:${PORT}>
	ProxyPreserveHost On
	ProxyRequests Off

	ProxyPass /healthz !
	Alias /healthz /var/www/static/healthz
	<Directory "/var/www/static">
		Options -Indexes
		Require all granted
	</Directory>

	# CLI API (livepeer -cliAddr) — admin scope only; path prefix so one public PORT works on Railway.
	# Redirect the bare prefix so "/__signer_cli" and "/__signer_cli/" both reach the CLI upstream
	# (without the redirect, the bare path would fall through to the catch-all "/" ProxyPass below).
	RedirectMatch permanent ^/__signer_cli$ /__signer_cli/
	ProxyPass /__signer_cli/ ${SIGNER_CLI_HTTP_ADDR}/
	ProxyPassReverse /__signer_cli/ ${SIGNER_CLI_HTTP_ADDR}/

	ProxyPass /status ${SIGNER_HTTP_ADDR}/status
	ProxyPassReverse /status ${SIGNER_HTTP_ADDR}/status

	ProxyPass / ${SIGNER_HTTP_ADDR}/
	ProxyPassReverse / ${SIGNER_HTTP_ADDR}/

	<Location "/healthz">
		AuthType None
		Require all granted
	</Location>

	<Location "/status">
		AuthType None
		Require all granted
	</Location>

	<LocationMatch "^/__signer_cli(?:/|$)">
		AuthType jwt-bearer
		AuthName "pymthouse-signer-cli"
		AuthJWTSignatureAlgorithm RS256
		AuthJWTSignaturePublicKeyFile ${JWT_PEM_PATH}
		AuthJWTIss "${OIDC_ISSUER}"
		AuthJWTAud "${OIDC_AUDIENCE}"
		AuthJWTAttributeUsername sub
		AuthJWTLeeway 10

		# Clear the bearer in the fixups phase (default) — after mod_authnz_jwt has verified it.
		# Using "early" would strip the header before the auth phase and break verification.
		RequestHeader unset Authorization

		Require jwt-claim scope=admin
	</LocationMatch>

	<LocationMatch "^/(?!(?:healthz|status|__signer_cli)(?:/|$))">
		AuthType jwt-bearer
		AuthName "pymthouse-signer-http"
		AuthJWTSignatureAlgorithm RS256
		AuthJWTSignaturePublicKeyFile ${JWT_PEM_PATH}
		AuthJWTIss "${OIDC_ISSUER}"
		AuthJWTAud "${OIDC_AUDIENCE}"
		AuthJWTAttributeUsername sub
		AuthJWTLeeway 10

		# Strip the bearer before proxying upstream, but not before mod_authnz_jwt verifies it.
		RequestHeader unset Authorization

		Require jwt-claim scope=sign:job
	</LocationMatch>
</VirtualHost>

# Dedicated admin CLI listener. Same upstream as /__signer_cli, but its own
# port so ops can firewall/observe it separately. Requires scope=admin.
<VirtualHost *:${CLI_PORT}>
	ServerName localhost
	ProxyPreserveHost On
	ProxyRequests Off

	ProxyPass /healthz !
	Alias /healthz /var/www/static/healthz
	<Location "/healthz">
		AuthType None
		Require all granted
	</Location>

	ProxyPass / ${SIGNER_CLI_HTTP_ADDR}/
	ProxyPassReverse / ${SIGNER_CLI_HTTP_ADDR}/

	<LocationMatch "^/(?!healthz(?:/|$))">
		AuthType jwt-bearer
		AuthName "pymthouse-signer-cli-port"
		AuthJWTSignatureAlgorithm RS256
		AuthJWTSignaturePublicKeyFile ${JWT_PEM_PATH}
		AuthJWTIss "${OIDC_ISSUER}"
		AuthJWTAud "${OIDC_AUDIENCE}"
		AuthJWTAttributeUsername sub
		AuthJWTLeeway 10

		RequestHeader unset Authorization

		Require jwt-claim scope=admin
	</LocationMatch>
</VirtualHost>
