# Snyk policy file.
version: v1.25.0

exclude:
  global:
    # Third-party trees are not first-party code under test.
    - node_modules/**

  code:
    # Reviewed Snyk Code exclusion (SAST only).
    #
    # src/lib/openmeter/konnect-fetch.ts is the custom fetch wrapper handed to the
    # OpenMeter SDK for Kong Konnect routing. Snyk Code reports a HIGH SSRF
    # (javascript/Ssrf) because the SDK-built request URL flows into fetch. This is
    # a reviewed false positive: before any request leaves the process the wrapper
    # rejects any origin other than the configured metering origin and rebuilds the
    # outbound URL from that trusted origin, carrying over only the already
    # origin-checked path and query — so the destination host can never be
    # influenced by request input. Snyk Code does not model the env-configured
    # (non-literal) origin allowlist as a sanitizer, so it still flags the
    # path-level taint. The wrapper is isolated in this single, fully unit-tested
    # file so the exclusion is as narrow as possible; all other source keeps Snyk
    # Code coverage. The SSRF guard itself is covered by konnect-routes.test.ts.
    - src/lib/openmeter/konnect-fetch.ts
